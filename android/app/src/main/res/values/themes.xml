<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- DayNight so night mode follows the system; the web app's "system"
         theme option reads that through prefers-color-scheme. The window
         background matches the PWA manifest's background_color so there is no
         white flash before the WebView paints.

         The bars are left to MainActivity.applyEdgeToEdge, which makes them
         transparent, and their icon colours to BarsBridge, which tracks the
         sky. Setting statusBarColor here would just be overwritten. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/window_bg</item>
        <!-- Let the page paint into the cutout area on notched phones rather
             than letterboxing it. Ignored below API 28. -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
